{
  "name": "ghostuser-agent",
  "version": "0.0.1",
  "description": "Autonomous agent: AI personas that navigate live websites and find UX bugs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ghostuser-agent": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ghostuser-core": "^0.0.1",
    "@anthropic-ai/sdk": "^0.32.0",
    "@inquirer/prompts": "^7.0.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "license": "MIT",
  "author": "Miloš Savić <milos@negotiatewind.com>",
  "engines": {
    "node": ">=20"
  }
}
