{
  "name": "ghostuser-core",
  "version": "0.0.3",
  "description": "Core engine: AI personas that simulate users to find UX bugs in screenshots.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./personas": {
      "types": "./dist/persona.d.ts",
      "import": "./dist/persona.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
